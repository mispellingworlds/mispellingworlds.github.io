---
import Layout from '../layouts/BaseLayout.astro';
import FluidText from '../fluidText.astro';
---

<Layout title="mispellingworlds">
  <div class="master-stack">
    
    <div class="text-section">
      <div class="desktop-only">
        <FluidText text="ive wasted 2 much time so now im making space" tag="h1" />
      </div>
      <div class="mobile-only">
        <FluidText text="ive wasted 2 much time" tag="h1" />
        <FluidText text="so now im making space" tag="h1" />
      </div>
    </div>

  
    <div class="nav-row">
      <a href="/about" >About</a>
      <a href="/posts">Posts</a>
      <a href="/images">Images</a>
      <a href="/etc">Other</a>
    </div>

    <div class="image-section">
      <img src="/jesterbw.webp" alt="BW Fool Madcap" />
    </div>
  
  </div>

</Layout>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: white;
  }

  .master-stack {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100vw;
  }

  /* Titolo in alto */
  .text-section {
    width: 100%;
    flex: 0 0 auto; 
    padding: 1%;
  }

  /* Immagine che fa da Banner */
  .image-section {
    width: 100%;
    flex: 0 0 auto;
    display: flex;         /* Attiva flexbox sul contenitore */
    justify-content: center; /* Centra l'immagine orizzontalmente */
  }

  .image-section img {
    object-fit: contain;   /* Evita distorsioni */
    height: 70%;
    width: auto;           /* Mantiene le proporzioni corrette */
  }

.nav-row {
  display: flex;
  flex-direction: row; /* Li mette sulla stessa riga */
  justify-content: center; /* Li spinge tutti a destra */
  gap: 5%; /* Spazio orizzontale tra un link e l'altro */
  width: 100%;
  box-sizing: border-box;
}

.nav-row a {
  text-decoration: none;
  color: rgb(101, 101, 101);
  font-family: 'Cursive', sans-serif; 
  font-size: 5rem;
  text-transform: lowercase;
}


@media (max-width: 768px) {
  .nav-row {
    justify-content: center; /* Al centro su mobile per equilibrio */
    gap: 1rem;
  }
}

  /* Fix per h1 del FluidText */
  h1 {
    margin: 0 !important;
    line-height: 0.9;
  }

  @media (max-width: 768px) {
    .image-section img {
      width: 90%; /* Più basso su mobile */
    }
    .nav-container {
      justify-content: center; /* Centrati su mobile per ordine */
    }
    .nav-column {
      text-align: center;
    }
    .nav-row {
      gap: 9%;
    }
  }
</style>