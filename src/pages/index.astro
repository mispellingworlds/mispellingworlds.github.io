---
import Layout from '../layouts/BaseLayout.astro';
import FluidText from '../fluidText.astro';
---
<Layout title="mispellingworlds">
  <div class="master-stack">
    
    <div class="text-section">
      <div class="desktop-only">
        <FluidText text="ive wasted 2 much time so now im making space" tag="h1" />
      </div>
      <div class="mobile-only">
        <FluidText text="ive wasted 2 much time" tag="h1" />
        <FluidText text="so now im making space" tag="h1" />
      </div>
    </div>

    <div class="image-section">
      <img src="/plus.png" alt="" />
    </div>

  </div>
</Layout>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    height: 100vh;
    overflow: hidden;
    background-color: white;
  }

  .master-stack {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100%;
  }

  .text-section {
    width: 100%;
    flex: 0 0 auto; /* Prende solo lo spazio strettamente necessario */
    padding: 0 0 0 0; /* Rimosso padding inferiore */
    box-sizing: border-box;
  }

  .image-section {
    flex: 1; /* Occupa tutto lo spazio rimasto */
    display: flex;
    align-items: flex-start; /* Attacca l'immagine in alto, subito dopo il testo */
    justify-content: flex-start; /* Allinea a sinistra come nello screenshot */
    overflow: hidden;
  }

  .image-section img {
    height: 100%; /* L'immagine scala per riempire l'altezza rimanente */
    width: auto;
    object-fit: contain;
  }

  /* Rimuovi eventuali margini dai tag h1 generati da FluidText */
  h1 {
    margin: 0 !important;
    padding: 0 !important;
    line-height: 0.9; /* Stringe ulteriormente lo spazio tra le righe */
  }
</style>