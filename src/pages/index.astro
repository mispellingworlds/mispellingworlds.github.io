---
import Layout from '../layouts/BaseLayout.astro';
import FluidText from '../fluidText.astro';
---

<Layout title="mispellingworlds">
  <div class="master-stack">
    
    <div class="text-section">
      <div class="desktop-only">
        <FluidText text="ive wasted too much time so now im making space" tag="h1" />
      </div>
      <div class="mobile-only">
        <FluidText text="ive wasted too much time" tag="h1" />
        <FluidText text="so now im making space" tag="h1" />
      </div>
    </div>

    <div class="image-section">
      <img src="/patterns_homescreen.webp" alt="Banner Pattern" />
    </div>
    
    <div class="nav-row">
      <a href="/about" >About</a>
      <a href="/posts">Posts</a>
      <a href="/images">Images</a>
      <a href="/etc">Etc</a>
    </div>
  </div>
</Layout>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: white;
  }

  .master-stack {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100vw;
  }

  /* Titolo in alto */
  .text-section {
    width: 100%;
    flex: 0 0 auto; 
    padding: 1%;
  }

  /* Immagine che fa da Banner */
  .image-section {
    width: 100%;
    flex: 0 0 auto; /* Altezza basata sull'immagine o fissa */
  }

  .image-section img {
    width: 100%;
    height: 65vh; /* Regola l'altezza del banner qui */
    object-fit: fill; /* Mantiene lo stretch che volevi */
    display: block;
  }

.nav-row {
  display: flex;
  flex-direction: row; /* Li mette sulla stessa riga */
  justify-content: center; /* Li spinge tutti a destra */
  gap: 2rem; /* Spazio orizzontale tra un link e l'altro */
  padding: 1.5rem 2%; /* Distanza dal bordo dell'immagine e dai lati */
  width: 100%;
  box-sizing: border-box;
}

.nav-row a {
  text-decoration: none;
  color: black;
  font-family: 'Nohemi-Medium', sans-serif; 
  font-size: 2rem;
  text-transform: lowercase;
}

.nav-row a:hover {
  opacity: 0.5;
}

@media (max-width: 768px) {
  .nav-row {
    justify-content: center; /* Al centro su mobile per equilibrio */
    gap: 1rem;
  }
}

  /* Fix per h1 del FluidText */
  h1 {
    margin: 0 !important;
    line-height: 0.9;
  }

  @media (max-width: 768px) {
    .image-section img {
      height: 25vh; /* Più basso su mobile */
    }
    .nav-container {
      justify-content: center; /* Centrati su mobile per ordine */
    }
    .nav-column {
      text-align: center;
    }
  }
</style>