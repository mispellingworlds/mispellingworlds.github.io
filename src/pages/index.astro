---
import Layout from '../layouts/BaseLayout.astro';
import FluidText from '../fluidText.astro';
---

<Layout title="mispellingworlds">
  <div class="master-stack">
    
    <div class="text-section">
      <div class="desktop-only">
        <FluidText text="ive wasted 2 much time so now im making space" tag="h1" />
      </div>
      <div class="mobile-only">
        <FluidText text="ive wasted 2 much time" tag="h1" />
        <FluidText text="so now im making space" tag="h1" />
      </div>
    </div>

    <div class="image-section">
      <img src="/patterns_homescreen2.webp" alt="chapu" />
    </div>
   

  </div>
</Layout>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: white;
  }

  .master-stack {
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100vw;
  }

  .text-section {
    /* Il testo occupa la parte superiore. 
       Dandogli larghezza 100%, FluidText tornerà grande. */
    width: 100%;
    flex: 0 0 auto; 
    box-sizing: border-box;
    padding-left: 1%;
    padding-right: 1%;
    padding-top: 1%;
  }

 .image-section {
    flex: 1;
    display: flex;
    min-height: 0;
  }

.image-section img {
    /* TRUCCO: forza l'immagine a coprire tutta la larghezza 
       anche se deve deformarsi leggermente per l'altezza */
    width: 100%;
    object-fit: fill; /* "Stretch" invece di "contain" */
  }

  /* Desktop: Immagine più schiacciata (es. 30% dell'altezza rimanente) */
  @media (min-width: 769px) {
    .image-section img {
      height: 50%; 
    }
  }

  /* Se su mobile il testo è troppo, puoi regolare il padding */
  @media (max-width: 768px) {
    .image-section img {
      height: 25%; 
    }
  }
</style>