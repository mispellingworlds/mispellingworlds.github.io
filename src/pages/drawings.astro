---
import Layout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';

// Definisci qui la cartella specifica per questa pagina
const drawingsFolder = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/drawings/*.{jpeg,jpg,png,gif}'
);
---

<Layout title="cartografia">
  <Header />
  <Gallery folder={drawingsFolder} />
  <Footer />
</Layout>