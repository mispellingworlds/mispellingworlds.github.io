---

<style>
  .image-section {
    width: 100%;
    flex: 0 0 auto;
    display: flex;         /* Attiva flexbox sul contenitore */
    justify-content: center; /* Centra l'immagine orizzontalmente */
  }

  .image-section img {
  height: 20vh; /* O una misura fissa se vuoi consistenza */
  width: auto;
  object-fit: contain;
  content-visibility: auto;
  }

.home-link {
  position: relative;
}

.hover-text {
  position: absolute;
  left: 100%;
  top: 25%;
  margin-left: 1rem;
  opacity: 0;
  transform: translateX(-5px);
  transition: all 0.2s ease;
  white-space: nowrap;
  font-family: 'Cursive', sans-serif;
  font-size: 3.2rem;
  color: rgb(128, 128, 128);
}

.home-link:hover .hover-text {
  opacity: 1;
  transform: translateX(0);
}
</style>

<footer>
  <div class="image-section">
    <a href="/" class="home-link">
      <img src="/home-image.png" alt="Home Image" />
      <span class="hover-text">home</span>
    </a>
  </div>
</footer>