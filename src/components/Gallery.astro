---
import { Image } from 'astro:assets';

interface Props {
  // Definiamo il tipo per il glob di Astro
  folder: Record<string, () => Promise<{ default: ImageMetadata }>>;
}

const { folder } = Astro.props;

// Risolviamo le immagini passate dalla pagina
const images = await Promise.all(
  Object.values(folder).map(async (importImg) => {
    const img = await importImg();
    return img.default;
  })
);
---

<div id="gallery" class="text-section">
    {images.map((img) => (
        <Image 
            src={img} 
            alt="drawing" 
            format="webp"
            class="thumb" 
            data-fullsrc={img.src}
        />
    ))}
</div>

<div id="lightbox" class="hidden">
    <img id="lightbox-img" src="" alt="full view" />
</div>

<script>
    function initLightbox() {
        const thumbs = document.querySelectorAll<HTMLImageElement>('.thumb');
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

        if (!lightbox || !lightboxImg) return;

        thumbs.forEach((img) => {
            img.onclick = () => {
                const fullSrc = img.getAttribute('data-fullsrc');
                if (fullSrc) {
                    lightboxImg.src = fullSrc;
                    lightbox.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';
                }
            };
        });

        lightbox.onclick = () => {
            lightbox.classList.add('hidden');
            lightboxImg.src = '';
            document.body.style.overflow = '';
        };
    }

    // Inizializza
    initLightbox();
    // Se usi ViewTransitions di Astro, serve questo listener:
    document.addEventListener('astro:after-swap', initLightbox);
</script>

<style>
#gallery {
    column-count: 3; /* Numero di colonne */
    column-gap: 30px; /* Spazio orizzontale tra colonne */
    width: 80%;
    margin: 0 auto;
}

.thumb {
    width: 100%;
    height: auto; /* Fondamentale: l'altezza deve essere naturale */
    display: block;
    margin-bottom: 30px; /* Spazio verticale tra le immagini */
    object-fit: contain;
    cursor: pointer;
    transition: transform 0.25s ease;
    /* Impedisce che l'immagine venga spezzata tra due colonne */
    break-inside: avoid;
}

.thumb:hover {
    transform: scale(1.05);
    z-index: 3;
}

#lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.98);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    touch-action: none;
}

#lightbox.hidden {
    display: none;
}

#lightbox img {
    max-width: 95vw;
    max-height: 95vh;
    object-fit: contain;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
}

.hidden {
    display: none;
}

@media (max-width: 768px) {
    #gallery {
        column-count: repeat(2, 1fr);
    }
}
</style>