---
interface Props {
  text: string;
  tag?: 'h1' | 'h2' | 'h3' | 'div' | 'p';
}

const { text, tag: Tag = 'div' } = Astro.props;
const letters = text.split("");
// Generiamo un ID unico per gestire più istanze nella stessa pagina
const id = `fluid-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="fluid-container" id={id}>
  <Tag class="fluid-target">
    {letters.map((char) => (
      <span class="char">{char === " " ? "\u00A0" : char}</span>
    ))}
  </Tag>
</div>

<style>
.fluid-container {
    width: 100%;
    display: block;
    overflow: visible; /* Cambiato da hidden a visible per non tagliare l'antialiasing */
    line-height: 1;
    padding-right: 0.1em; /* Piccolo buffer laterale basato sulla dimensione del font */
  }
  .fluid-target {
    display: inline-block;
    white-space: nowrap;
    font-size: 8vw; 
    font-family: 'Nohemi-Medium', sans-serif;
    margin: 0;
    line-height: 1.1;
    transform-origin: left center;
    visibility: visible;
    /* Ottimizzazione rendering */
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  .char {
    display: inline-block;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
  }
</style>

<script is:inline define:vars={{ id }}>
  // Usiamo is:inline per eseguire lo script nel momento esatto in cui viene letto l'HTML
  (function() {
    const container = document.getElementById(id);
    if (!container) return;
    const target = container.querySelector('.fluid-target');
    
    function scale() {
      // Rimuovi il reset a 10px che causava il salto visivo
      const cWidth = container.getBoundingClientRect().width;
      const tWidth = target.getBoundingClientRect().width;
      
      if (tWidth > 0) {
        const currentSize = parseFloat(window.getComputedStyle(target).fontSize);
        const ratio = cWidth / tWidth;
        const newSize = currentSize * ratio;

        // Applica solo se la differenza è significativa (> 2px) 
        // per evitare micro-oscillazioni fastidiose
        if (Math.abs(newSize - currentSize) > 2) {
          target.style.fontSize = newSize + 'px';
        }
      }
    }

    // Eseguiamo subito
    scale();

    // Eseguiamo al caricamento dei font per correggere eventuali micro-differenze
    if ("fonts" in document) {
      document.fonts.ready.then(scale);
    }

    // Gestione resize con ricalcolo immediato (senza timeout per feedback istantaneo)
    window.addEventListener('resize', scale);

    // Click handler delegato (più performante)
    container.addEventListener('click', (e) => {
      if (e.target.classList.contains('char')) {
        e.target.style.color = '#ffffff'; // O la tua logica di palette
      }
    });
  })();
</script>