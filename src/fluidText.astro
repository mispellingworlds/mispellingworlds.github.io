---
interface Props {
  text: string;
  tag?: 'h1' | 'h2' | 'h3' | 'div' | 'p';
}

const { text, tag: Tag = 'div' } = Astro.props;
const letters = text.split("");
---

<div class="fluid-container">
  <Tag class="fluid-target">
    {letters.map((char: string) => (
      <span class="char">{char === " " ? "\u00A0" : char}</span>
    ))}
  </Tag>
</div>

<style>
  .fluid-container {
    width: 100%;
    display: block;
    overflow: visible; /* Evita tagli visivi a destra */
    line-height: 1;
    padding: 0;
  }
  .fluid-target {
    display: inline-block;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    line-height: 1.1;
    font-family: 'Nohemi-Medium', sans-serif;
    margin: 0;
    /* Transizione rapida per nascondere il ricalcolo al resize */
    transition: opacity 0.05s ease-in;
    transform-origin: left center;
  }
  .fluid-target.is-ready {
    opacity: 1;
    visibility: visible;
  }
  .char {
    display: inline-block;
    user-select: none;
    will-change: color;
  }
</style>

<script>
  const palette = ['#787878', '#878787', '#424242', '#ababab', '#242424', '#ededed', '#1c1c1c'];
  let resizeTimeout: number;
  
  function handleLetterClick(event: MouseEvent) {
    const el = event.target as HTMLElement;
    if (el?.classList.contains('char')) {
      el.style.color = palette[Math.floor(Math.random() * palette.length)];
    }
  }

  function scaleElement(container: HTMLElement) {
    const target = container.querySelector('.fluid-target') as HTMLElement;
    if (!target) return;

    // Se l'elemento è nascosto (display: none), resettiamo e usciamo
    if (container.offsetWidth === 0) {
      target.classList.remove('is-ready');
      return;
    }

    // Misurazione senza cambiare position (evita bug sui click)
    target.style.fontSize = '10px'; 
    
    // getBoundingClientRect è fondamentale per i sub-pixel (evita il testo tagliato)
    const containerWidth = container.getBoundingClientRect().width;
    const textWidth = target.getBoundingClientRect().width;
    
    if (textWidth > 0) {
      // Moltiplicatore 0.99 per sicurezza contro gli arrotondamenti dei browser
      const ratio = (containerWidth / textWidth) * 1;
      target.style.fontSize = `${10 * ratio}px`;
      
      // Forza il rendering prima di mostrare
      void target.offsetWidth;
      target.classList.add('is-ready');
    }
  }

  function setup() {
    document.querySelectorAll('.fluid-container').forEach(c => scaleElement(c as HTMLElement));
  }

  // Event Listeners
  document.addEventListener('click', handleLetterClick);
  document.addEventListener('astro:page-load', setup);
  
  if ("fonts" in document) {
    document.fonts.ready.then(setup);
  }

  window.addEventListener('resize', () => {
    // Nascondiamo il testo durante il resize per evitare l'effetto "tagliato"
    document.querySelectorAll('.fluid-target').forEach(t => t.classList.remove('is-ready'));
    
    clearTimeout(resizeTimeout);
    resizeTimeout = window.setTimeout(setup, 50); // Piccolo debounce per stabilità
  });

  // Init
  setup();
</script>