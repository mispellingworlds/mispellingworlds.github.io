a:{"metadata":[["$","title","0",{"children":"the flicker (pure digital reconstruction) — cartografia"}],["$","meta","1",{"name":"description","content":"A pure digital reconstruction of Tony Conrad 1966 stroboscopic film The Flicker, algorithmically rebuilt from the original frame data using solid black and white frames at 24fps."}],["$","link","2",{"rel":"manifest","href":"/site.webmanifest","crossOrigin":"$undefined"}],["$","meta","3",{"name":"mobile-web-app-capable","content":"yes"}],["$","meta","4",{"name":"apple-mobile-web-app-title","content":"mispelling worlds"}],["$","meta","5",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],["$","link","6",{"rel":"shortcut icon","href":"/favicon.ico"}],["$","link","7",{"rel":"icon","href":"/favicon-96x96.png","type":"image/png","sizes":"96x96"}],["$","link","8",{"rel":"icon","href":"/favicon.svg","type":"image/svg+xml"}],["$","link","9",{"rel":"apple-touch-icon","href":"/apple-touch-icon.png"}],["$","$L13","10",{}]],"error":null,"digest":"$undefined"}
